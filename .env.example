# ─── 다이소 안전사고 예방 AI — 환경변수 설정 ───
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# ─── LLM 모드 ───
# true로 설정하면 Bedrock 호출 없이 규칙 기반 Mock 가이드 생성
# 비워두거나 false로 설정하면 Bedrock 호출 시도
USE_MOCK_LLM=false

# ─── Bedrock API 키 (권장) ───
# AWS 콘솔 > Bedrock > API keys에서 생성
# 이 값이 있으면 IAM 자격증명 없이 Bedrock 호출 가능
BEDROCK_API_KEY=

# ─── Bedrock 설정 ───
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ─── AWS IAM 자격증명 (API 키 없을 때 대안) ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # 임시 자격증명 사용 시

# ─── 카카오 지오코딩 (build_dataset.py Step 1용) ───
# KAKAO_REST_API_KEY=
